dedOn":1729382019741,"profileUrl":"https://www.tiktok.com/@thepiratecandyshop","iconEnabled":true,"serviceName":"tiktok-unauth"},{"serviceId":64,"screenname":"Instagram","addedOn":1729381985882,"profileUrl":"https://www.instagram.com/thepiratecandyshop/","iconEnabled":true,"serviceName":"instagram-unauth"},{"serviceId":60,"screenname":"Facebook","addedOn":1729381965365,"profileUrl":"https://www.facebook.com/thepiratecandyshop/","iconEnabled":true,"serviceName":"facebook-unauth"},{"serviceId":69,"screenname":"YouTube","addedOn":1734840598381,"profileUrl":"https://www.youtube.com/@ThePirateCandyShop/shorts","iconEnabled":true,"serviceName":"youtube-unauth"}],"typekitId":"","statsMigrated":false,"imageMetadataProcessingEnabled":false,"screenshotId":"895f67e43affb2edcb20030c5235af6bffe542fda7a7a1b96a669b4691126e3d","captchaSettings":{"enabledForDonations":false},"showOwnerLogin":false},"websiteSettings":{"id":"66fa065015ecc429d95461d5","websiteId":"66fa065015ecc429d95461d0","subjects":[],"country":"US","state":"FL","simpleLikingEnabled":true,"mobileInfoBarSettings":{"style":3,"isContactEmailEnabled":true,"isContactPhoneNumberEnabled":true,"isLocationEnabled":true,"isBusinessHoursEnabled":true},"announcementBarSettings":{"style":2,"text":"<p class=\"\" data-rte-preserve-empty=\"true\" style=\"white-space:pre-wrap;\">Enjoy <strong>FREE SHIPPING </strong>on<strong> U.S. orders $60+ </strong>and <strong>International orders $120+!</strong></p>","clickthroughUrl":{"url":"/shopping","newWindow":false}},"popupOverlaySettings":{"style":1,"showOnScroll":true,"scrollPercentage":25,"showOnTimer":true,"timerDelay":0,"showUntilSignup":false,"displayFrequency":7,"enableMobile":true,"enabledPages":[],"showOnAllPages":true,"version":1},"commentLikesAllowed":true,"commentAnonAllowed":true,"commentThreaded":true,"commentApprovalRequired":false,"commentAvatarsOn":true,"commentSortType":2,"commentFlagThreshold":0,"commentFlagsAllowed":true,"commentEnableByDefault":true,"commentDisableAfterDaysDefault":0,"disqusShortname":"","commentsEnabled":false,"contactPhoneNumber":"+18139575286","businessHours":{"monday":{"text":"10am - 8pm","ranges":[{"from":600,"to":1200}]},"tuesday":{"text":"10am - 8pm","ranges":[{"from":600,"to":1200}]},"wednesday":{"text":"10am - 8pm","ranges":[{"from":600,"to":1200}]},"thursday":{"text":"10am - 8pm","ranges":[{"from":600,"to":1200}]},"friday":{"text":"10am - 9pm","ranges":[{"from":600,"to":1260}]},"saturday":{"text":"10am - 9pm","ranges":[{"from":600,"to":1260}]},"sunday":{"text":"11am - 6pm","ranges":[{"from":660,"to":1080}]}},"contactEmail":"info@thepiratecandyshop.com","storeSettings":{"returnPolicy":"<p><strong>Return Policy</strong></p><p>Due to the perishable nature of candy, <strong>all sales are final</strong>. We do not accept returns or exchanges for any reason, including dissatisfaction with flavor, texture, or appearance.</p><p>\u2022 In the event of an issue caused by <strong>The Pirate Candy Shop</strong> (e.g., incorrect item shipped), we will work to rectify the situation promptly.</p><p>\u2022 Refunds, when applicable, will only be issued for damaged or missing items verified by our team at our discretion.</p>","termsOfService":"<p>Welcome to <strong>The Pirate Candy Shop</strong>. By accessing or using our website (<a href=\"https://www.thepiratecandyshop.com/\">https://www.thepiratecandyshop.com/</a>), you agree to comply with and be bound by these Terms and Conditions. If you do not agree with these terms, please do not use our site or services.</p><p>These Terms and Conditions constitute a legally binding agreement between you (\u201CCustomer,\u201D \u201CUser\u201D) and <strong>The Pirate Candy Shop</strong> (\u201Cwe,\u201D \u201Cus,\u201D \u201Cour\u201D).</p><p></p><p><strong>1. Website Use</strong></p><p></p><p><strong>Eligibility</strong></p><p>You must be at least 18 years old or have parental or legal guardian consent to use this site or make purchases.</p><p></p><p><strong>Prohibited Activities</strong></p><p>You agree not to:</p><p>\u2022 Use the site for unlawful purposes.</p><p>\u2022 Attempt to gain unauthorized access to our systems.</p><p>\u2022 Copy, distribute, or misuse any content or intellectual property from the website.</p><p>\u2022 Engage in any activity that disrupts the site\u2019s functionality.</p><p></p><p>We reserve the right to not deliver services to users for violations of these terms.</p><p></p><p><strong>2. Intellectual Property</strong></p><p>All content on this site, including text, photos, logos, and designs, are the property of <strong>The Pirate Candy Shop</strong> and are protected under copyright, trademark, and other applicable laws. You may not reproduce, distribute, or display our content without prior written permission.</p><p></p><p><strong>3. Orders and Transactions</strong></p><p></p><p><strong>Pricing and Availability</strong></p><p>\u2022 All prices are listed in USD and are subject to change without notice.</p><p>\u2022 Products are subject to availability. If an item is unavailable, we reserve the right to cancel the order and issue a full refund.</p><p></p><p><strong>Order Confirmation</strong></p><p>An order is considered confirmed once payment has been processed and you receive an email confirmation. We reserve the right to refuse or cancel orders for any reason, including suspected fraud or pricing errors.</p><p></p><p><strong>Payment</strong></p><p>We accept major credit cards, debit cards, and other payment methods as displayed during checkout. Payments are securely processed through third-party payment providers. We do not store payment details.</p><p></p><p><strong>4. Shipping Policy</strong></p><p>\u2022 Shipping is available to all 50 U.S. states, including Alaska and Hawaii. We do not ship internationally.</p><p>\u2022 <strong>Flat Rates:</strong></p><p>\u2022 Standard Shipping: 3\u20137 business days.</p><p>\u2022 Priority Shipping: $9.99 1\u20133 business days.</p><p>\u2022 Please review our <a target=\"\" href=\"https://www.thepiratecandyshop.com/shipping-policy\"><u>Shipping Policy</u></a> for more detailed information.</p><p></p><p><strong>5. Returns and Refunds</strong></p><p></p><p>Due to the perishable nature of candy, <strong>all sales are final</strong>, and we do not accept returns or exchanges.</p><p>\u2022 Refunds may be issued at our discretion for cases such as incorrect or damaged orders.</p><p>\u2022 If you encounter an issue, contact us within <strong>48 hours</strong> of delivery with your order number and photos of the items.</p><p></p><p><strong>6. Privacy</strong></p><p></p><p>Your privacy is important to us. Please review our <a target=\"\" href=\"https://www.thepiratecandyshop.com/privacy-policy\"><u>Privacy Policy</u></a> for information about how we collect, use, and protect your data.</p><p></p><p><strong>7. Limitation of Liability</strong></p><p></p><p>\u2022 <strong>The Pirate Candy Shop</strong> is not responsible for:</p><p>\u2022 Delays caused by shipping carriers.</p><p>\u2022 Loss or theft of packages marked as delivered by the carrier.</p><p>\u2022 Allergic reactions, food intolerances or dietary concerns.</p><p>\u2022 To the fullest extent permitted by law, our liability is limited to the amount paid for the affected order.</p><p></p><p><strong>8. Dispute Resolution</strong></p><p></p><p>Any disputes arising from your use of the site or purchases made will be governed by the laws of the State of Florida. Disputes must be resolved through binding arbitration in Florida, and you waive the right to participate in any class-action lawsuit.</p><p></p><p><strong>9. Modifications to Terms</strong></p><p></p><p>We reserve the right to modify these Terms and Conditions at any time. Changes will be effective upon posting on this page. Continued use of the site constitutes your acceptance of the updated terms.</p><p></p><p><strong>10. Contact Information</strong></p><p></p><p>If you have questions or concerns about these Terms and Conditions, please contact us at <a href=\"mailto:info@thepiratecandyshop.com\">info@thepiratecandyshop.com</a></p><p></p><p>By using our site or making a purchase, you agree to these Terms and Conditions. Thank you for choosing <strong>The Pirate Candy Shop</strong>! We look forward to bringing exotic overseas sweets to you and your family!</p>","privacyPolicy":"<p><strong>1. Introduction</strong></p><p>This Privacy Policy explains how The Pirate Candy Shop (\u201Cwe,\u201D \u201Cus,\u201D \u201Cour\u201D) collects, uses, and discloses your information through our e-commerce website, based in Florida, USA. We comply with applicable privacy laws, including GDPR (for European users) and CCPA (for California residents), and other relevant data protection laws.</p><p><strong>2. Information We Collect</strong></p><p>\u2022 Personal Information: When you purchase, register, or contact us, we may collect your name, email, billing address, and payment details.</p><p>\u2022 Usage Data: Through Google Analytics 4 (GA4), we collect usage data such as your IP address, device information, and browsing activity on our website.</p><p><strong>3. Cookies and Tracking</strong></p><p>We use cookies to enhance your experience and gather data. This includes:</p><p>\u2022 Analytics Cookies: Used to track visitor behavior on our site via GA4. These help us understand user interactions and improve our services.</p><p>\u2022 Functional Cookies: Essential for site functionality, such as remembering your cart.</p><p>\u2022 Third-Party Cookies: Used for marketing purposes, including tracking how you navigate and interact with our site.</p><p>You can manage cookie preferences through your browser settings.</p><p><strong>4. How We Use Your Data</strong></p><p>We use collected data to:</p><p>\u2022 Process orders and provide customer support.</p><p>\u2022 Improve website performance through GA4 insights.</p><p>\u2022 Conduct marketing and promotional activities.</p><p><strong>5. Data Sharing</strong></p><p>We may share data with third-party service providers for operational purposes (e.g., payment processors). We do not sell your personal data.</p><p><strong>6. Your Rights</strong></p><p>\u2022 GDPR Users: If you are in the EU, you have rights to access, rectify, or delete your personal data.</p><p>\u2022 CCPA Users: California residents can request information about data collection and opt out of the sale of personal data.</p><p><strong>7. Data Security</strong></p><p>We implement industry-standard security measures to protect your data from unauthorized access.</p><p><strong>8. Changes to This Policy</strong></p><p>We reserve the right to update this Privacy Policy. Changes will be posted on this page with an updated effective date.</p><p><strong>9. Contact Us</strong></p><p>For questions about this policy, contact us at <a href=\"mailto:info@thepiratecandyshop.com\"><u>info@thepiratecandyshop.com</u></a></p>","expressCheckout":false,"continueShoppingLinkUrl":"shopping","useLightCart":false,"showNoteField":false,"shippingCountryDefaultValue":"US","billToShippingDefaultValue":true,"showShippingPhoneNumber":true,"isShippingPhoneRequired":false,"showBillingPhoneNumber":true,"isBillingPhoneRequired":false,"currenciesSupported":["USD","CAD","GBP","AUD","EUR","CHF","NOK","SEK","DKK","NZD","SGD","MXN","HKD","CZK","ILS","MYR","RUB","PHP","PLN","THB","BRL","ARS","COP","IDR","INR","JPY","ZAR"],"defaultCurrency":"USD","selectedCurrency":"USD","measurementStandard":1,"orderConfirmationInjectCode":"// add this before event code to all pages where PII data postback is expected and appropriate \nttq.identify({\n\t\"email\": \"<hashed_email_address>\", // string. The email of the customer if available. It must be hashed with SHA-256 on the client side.\n\t\"phone_number\": \"<hashed_phone_number>\", // string. The phone number of the customer if available. It must be hashed with SHA-256 on the client side.\n\t\"external_id\": \"<hashed_external_id>\" // string. Any unique iden